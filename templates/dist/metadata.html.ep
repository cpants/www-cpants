% my $stash = stash('cpants');
% my $data = $stash->{data};
% my $distribution = $stash->{distribution};
% layout 'layout', 'cpants.requires_jsonview' => 1;

<div class="row">

%= include 'dist/_sidebar';

<div class="col-md-10">

%= include 'dist/_tab';

  <section>
  <h3>Metadata</h3>
  <pre id="json-collapsed" data-metadata="<%= encode_json($data->{metadata}) %>"></pre>
  </section>

</div>
</div>
